{
  "name": "@prodaric/ubl-validator",
  "version": "2.1.0-alpha.2",
  "description": "Validador de documentos UBL 2.1 (XML y JSON) conforme a esquemas OASIS",
  "author": "Prodaric",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prodaric/ubl-validator.git"
  },
  "bugs": {
    "url": "https://github.com/prodaric/ubl-validator/issues"
  },
  "homepage": "https://github.com/prodaric/ubl-validator#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js"
    },
    "./profile": {
      "types": "./dist/profile/index.d.ts",
      "import": "./dist/profile/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    }
  },
  "bin": {
    "ubl-validate": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "schemas:fetch": "node scripts/fetch-schemas.mjs",
    "schemas:registry": "node scripts/build-registry.mjs",
    "schemas:setup": "npm run schemas:fetch && npm run schemas:registry",
    "schemas:profiles:fetch": "node scripts/fetch-dian-schemas.mjs && node scripts/fetch-peppol-schemas.mjs && node scripts/build-profile-registry.mjs",
    "fixtures:minimal": "node scripts/generate-minimal-fixtures.mjs",
    "fixtures:dian:fetch": "node scripts/fetch-dian-fixtures.mjs",
    "fixtures:dian:verify": "node scripts/verify-dian-fixtures.mjs",
    "fixtures:dian": "npm run fixtures:dian:fetch",
    "prepublishOnly": "npm run test:ci"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "xml-xsd-engine": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@angular/forms": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/forms": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
